---
// Sticky mobile CTA bar — only shows on mobile, fixed to bottom
// Massive conversion driver for local service businesses
---

<div
  id="mobile-cta-bar"
  class="fixed bottom-0 left-0 right-0 z-50 md:hidden"
  style="transform: translateY(100%); opacity: 0;"
  aria-label="Quick contact bar"
>
  <!-- Safe area padding for iPhone notch -->
  <div class="bg-[#111111] border-t border-[#E31E24]/40 pb-safe">
    <div class="flex items-stretch">

      <!-- Call button (primary, takes up more space) -->
      <a
        href="tel:0265526131"
        class="flex-1 flex items-center justify-center gap-3 bg-[#E31E24] text-white font-bold text-base py-4 px-4 hover:bg-red-700 transition-colors active:scale-95"
        aria-label="Call Corney's on (02) 6552 6131"
      >
        <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
        </svg>
        <span>(02) 6552 6131</span>
      </a>

      <!-- Divider -->
      <div class="w-px bg-[#E31E24]/30"></div>

      <!-- Book button -->
      <a
        href="/contact/"
        class="flex items-center justify-center gap-2 bg-[#1A1A1A] text-white font-semibold text-sm py-4 px-5 hover:bg-[#2A2A2A] transition-colors active:scale-95"
        aria-label="Book a service"
      >
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <span>Book</span>
      </a>

    </div>
  </div>
</div>

<style>
  /* Safe area for iPhone home indicator */
  .pb-safe {
    padding-bottom: max(0px, env(safe-area-inset-bottom));
  }
</style>

<script>
  // Slide up mobile CTA bar after user has scrolled a bit
  const bar = document.getElementById('mobile-cta-bar');
  if (bar) {
    let shown = false;
    const showBar = () => {
      if (!shown && window.scrollY > 300) {
        shown = true;
        bar.style.transition = 'transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease';
        bar.style.transform = 'translateY(0)';
        bar.style.opacity = '1';
      }
    };
    window.addEventListener('scroll', showBar, { passive: true });
    // Also show if page is already scrolled on load
    showBar();
  }
</script>
