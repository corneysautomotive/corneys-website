---
// Hero component — homepage only
import homeContent from '../content/home.json';
import siteContent from '../content/site.json';

const hero = homeContent.hero;
---

<section
  id="hero"
  class="relative bg-[#1A1A1A] overflow-hidden flex items-center"
  aria-label="Hero section"
>
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-[#111111] via-[#1A1A1A] to-[#242424]"></div>

  <!-- Subtle grid texture overlay -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 40px 40px;"></div>

  <!-- Logo animation — right side -->
  <div
    id="hero-gear"
    class="absolute right-[2%] top-1/2 -translate-y-1/2 w-[420px] h-[420px] lg:w-[520px] lg:h-[520px] pointer-events-none select-none hidden md:flex items-center justify-center"
    aria-hidden="true"
  >
    <img
      src="/logos/logo-animated.svg"
      alt="Corney's Automotive"
      class="w-full max-w-sm mx-auto"
    />
  </div>

  <!-- Red accent bar left edge -->
  <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-[#E31E24]"></div>

  <div class="relative max-w-6xl mx-auto px-6 sm:px-8 lg:px-12 py-20 lg:py-32 w-full">
    <div class="max-w-2xl">

      <!-- Logo -->
      <div id="hero-logo" class="mb-8">
        <div class="flex items-center gap-3">
          <div class="w-1 h-10 bg-[#E31E24] rounded"></div>
          <div>
            <div class="font-display text-2xl sm:text-3xl font-extrabold text-white leading-none tracking-tight">CORNEY'S</div>
            <div class="text-xs font-semibold text-[#E31E24] uppercase tracking-[0.25em] mt-0.5">Automotive Services</div>
          </div>
        </div>
      </div>

      <!-- Tag line -->
      <p
        id="hero-tag"
        class="text-[#E31E24] font-semibold text-sm uppercase tracking-widest mb-4"
      >
        {hero.tagline}
      </p>

      <!-- Headline -->
      <h1
        id="hero-h1"
        class="font-display text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6"
      >
        {hero.headlineLine1} <br class="hidden sm:block" />
        <span class="text-[#E31E24]">{hero.headlineEmphasis}</span><br />
        {hero.headlineLine2}
      </h1>

      <!-- Sub copy -->
      <p
        id="hero-sub"
        class="text-gray-300 text-lg sm:text-xl leading-relaxed mb-10 max-w-xl"
      >
        {hero.subtext}
      </p>

      <!-- CTAs -->
      <div
        id="hero-ctas"
        class="flex flex-col sm:flex-row gap-4"
      >
        <a
          href={`tel:${siteContent.phoneTel}`}
          class="phone-pulse inline-flex items-center justify-center gap-2 bg-[#E31E24] hover:bg-red-700 text-white font-bold text-lg px-8 py-4 rounded-lg transition-all hover:scale-105 hover:shadow-[0_0_20px_rgba(227,30,36,0.4)] min-h-[56px]"
          aria-label={`Call Corney's Automotive on ${siteContent.phone}`}
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
          </svg>
          {siteContent.phone}
        </a>
        <a
          href="/contact/"
          class="inline-flex items-center justify-center gap-2 border-2 border-white/70 text-white hover:bg-white hover:text-[#1A1A1A] font-semibold text-lg px-8 py-4 rounded-lg transition-all hover:scale-105 min-h-[56px]"
        >
          Book a Service
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Trust badges -->
      <div
        id="hero-badges"
        class="mt-10 flex flex-wrap gap-5 text-sm text-gray-400"
      >
        {hero.badges.map((badge) => (
          <div class="flex items-center gap-2">
            <span class="text-[#E31E24] text-lg font-bold">✓</span>
            <span>{badge}</span>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  // Hero entrance sequence
  const tl = gsap.timeline({ delay: 0.2 });
  tl.to('#hero-logo',   { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, 0)
    .from('#hero-logo', { y: 16 }, 0)
    .to('#hero-tag',    { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' }, 0.25)
    .from('#hero-tag',  { y: 12 }, 0.25)
    .to('#hero-h1',     { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' }, 0.4)
    .from('#hero-h1',   { y: 20 }, 0.4)
    .to('#hero-sub',    { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, 0.35)
    .from('#hero-sub',  { y: 16 }, 0.35)
    .to('#hero-ctas',   { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' }, 0.5)
    .from('#hero-ctas', { y: 12 }, 0.5)
    .to('#hero-badges', { opacity: 1, duration: 0.5, ease: 'power2.out' }, 0.7);

  // Animated logo fade in
  gsap.to('#hero-gear', {
    opacity: 1,
    duration: 1.2,
    delay: 0.4,
    ease: 'power2.inOut'
  });
</script>
