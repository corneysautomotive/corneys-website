---
import homeContent from '../content/home.json';
import siteContent from '../content/site.json';

const whyUs = homeContent.whyUs;

const pointIcons = [
  `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
  `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>`,
  `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>`
];
---

<section class="py-16 lg:py-24 bg-[#1A1A1A] relative overflow-hidden" aria-label="Why choose Corney's">

  <!-- Subtle diagonal pattern background -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: repeating-linear-gradient(45deg, rgba(255,255,255,0.8) 0, rgba(255,255,255,0.8) 1px, transparent 0, transparent 50%); background-size: 12px 12px;"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-12 reveal">
      <p class="text-[#E31E24] font-semibold text-sm uppercase tracking-widest mb-2">{whyUs.tagline}</p>
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-white">
        {whyUs.heading}
      </h2>
      <span class="accent-line mx-auto"></span>
      <p class="mt-4 text-gray-400 text-lg max-w-xl mx-auto">
        {whyUs.subtext}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {whyUs.points.map((point, i) => (
        <div
          class="why-card reveal group bg-[#222222] rounded-2xl p-6 border border-[#2E2E2E] hover:border-[#E31E24]/50 hover:bg-[#252525] transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-black/30"
          style={`transition-delay: ${i * 80}ms`}
        >
          <!-- Icon -->
          <div class="w-14 h-14 rounded-xl bg-[#E31E24]/10 border border-[#E31E24]/20 flex items-center justify-center text-[#E31E24] mb-5 group-hover:bg-[#E31E24]/20 group-hover:border-[#E31E24]/40 transition-all duration-300" set:html={pointIcons[i]} />

          <h3 class="font-semibold text-white text-base mb-3 leading-tight">{point.title}</h3>
          <p class="text-gray-400 text-sm leading-relaxed">{point.desc}</p>
        </div>
      ))}
    </div>

    <!-- Google reviews mention -->
    <div class="mt-12 text-center reveal">
      <div class="inline-flex items-center gap-3 bg-[#222222] border border-[#2E2E2E] rounded-full px-6 py-3">
        <span class="text-[#E31E24] text-lg">★★★★★</span>
        <span class="text-gray-400 text-sm">
          Rated 5 stars by Taree locals —
          <a
            href={siteContent.googleMapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[#E31E24] font-medium hover:underline ml-1"
          >
            See Google Reviews
          </a>
        </span>
      </div>
    </div>

  </div>
</section>
