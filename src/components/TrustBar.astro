---
// Trust bar — sits between StatsBar and the services grid.
// JAX-style: short, confident, scannable value props with clean icons.
// White background — this is where the page pivots from the dark hero
// into the light, open content area.
---

<section class="bg-white border-b border-gray-100" aria-label="Why choose Corney's — key reasons">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-10">

      <div class="flex items-start gap-3">
        <div class="w-10 h-10 shrink-0 rounded-lg bg-[#E31E24]/10 flex items-center justify-center text-[#E31E24]">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        </div>
        <div>
          <h3 class="font-semibold text-[#1A1A1A] text-sm lg:text-base leading-tight">Licensed Across the Board</h3>
          <p class="text-gray-500 text-xs lg:text-sm mt-1 leading-relaxed">ARCtick · AUVIS · NSW Authorised Inspection Station</p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        <div class="w-10 h-10 shrink-0 rounded-lg bg-[#E31E24]/10 flex items-center justify-center text-[#E31E24]">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div>
          <h3 class="font-semibold text-[#1A1A1A] text-sm lg:text-base leading-tight">Honest, Upfront Pricing</h3>
          <p class="text-gray-500 text-xs lg:text-sm mt-1 leading-relaxed">Quote before any work. Invoice matches the quote. Always.</p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        <div class="w-10 h-10 shrink-0 rounded-lg bg-[#E31E24]/10 flex items-center justify-center text-[#E31E24]">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <div>
          <h3 class="font-semibold text-[#1A1A1A] text-sm lg:text-base leading-tight">Real Mechanics, Real Names</h3>
          <p class="text-gray-500 text-xs lg:text-sm mt-1 leading-relaxed">Jarrad, Don and Toby — the people working on your car.</p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        <div class="w-10 h-10 shrink-0 rounded-lg bg-[#E31E24]/10 flex items-center justify-center text-[#E31E24]">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <div>
          <h3 class="font-semibold text-[#1A1A1A] text-sm lg:text-base leading-tight">20+ Years in Taree</h3>
          <p class="text-gray-500 text-xs lg:text-sm mt-1 leading-relaxed">Same workshop. Same families. Generations of local cars.</p>
        </div>
      </div>

    </div>
  </div>
</section>
