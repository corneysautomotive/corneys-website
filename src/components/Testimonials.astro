---
// Testimonials — local Taree customer reviews
import homeContent from '../content/home.json';
import siteContent from '../content/site.json';

const testimonials = homeContent.testimonials;

function renderStars(count: number) {
  return '★'.repeat(count) + '☆'.repeat(5 - count);
}

function getInitial(name: string) {
  return name.charAt(0);
}
---

<section class="py-16 lg:py-24 bg-[#F5F5F5]" aria-label="Customer testimonials">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-12 reveal">
      <p class="text-[#E31E24] font-semibold text-sm uppercase tracking-widest mb-2">{testimonials.tagline}</p>
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-[#1A1A1A]">
        {testimonials.heading}
      </h2>
      <span class="accent-line mx-auto"></span>
      <p class="mt-4 text-gray-600 text-lg max-w-xl mx-auto">
        {testimonials.subtext}
      </p>
    </div>

    <!-- Reviews grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.reviews.map((review, i) => (
        <div
          class="testimonial-card reveal bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-lg hover:border-[#E31E24]/20 transition-all duration-300 hover:-translate-y-1"
          style={`transition-delay: ${i * 60}ms`}
        >
          <!-- Stars -->
          <div class="text-[#E31E24] text-xl mb-4 tracking-tight" aria-label={`${review.stars} out of 5 stars`}>
            {renderStars(review.stars)}
          </div>

          <!-- Quote text -->
          <blockquote class="text-gray-600 text-sm leading-relaxed mb-5 italic">
            "{review.text}"
          </blockquote>

          <!-- Reviewer info -->
          <div class="flex items-center gap-3">
            <!-- Avatar circle -->
            <div class="w-10 h-10 rounded-full bg-[#E31E24] flex items-center justify-center text-white font-bold text-sm shrink-0">
              {getInitial(review.name)}
            </div>
            <div>
              <div class="font-semibold text-[#1A1A1A] text-sm">{review.name}</div>
              <div class="text-gray-400 text-xs">{review.vehicle} · {review.location}</div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Google review link -->
    <div class="text-center mt-10 reveal">
      <a
        href={siteContent.googleMapsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-[#E31E24] font-semibold hover:underline text-sm"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
        </svg>
        See all our Google reviews ★★★★★
      </a>
    </div>

  </div>
</section>
