---
// Testimonials — local Taree customer reviews
import homeContent from '../content/home.json';
import siteContent from '../content/site.json';

const testimonials = homeContent.testimonials;

function renderStars(count: number) {
  return '★'.repeat(count) + '☆'.repeat(5 - count);
}

function getInitial(name: string) {
  return name.charAt(0);
}
---

<section class="py-20 lg:py-28 bg-white" aria-label="Customer testimonials">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header with rating summary on the right (JAX-style) -->
    <div class="mb-14 lg:mb-16 flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
      <div class="max-w-2xl">
        <p class="text-[#E31E24] font-semibold text-xs uppercase tracking-[0.2em] mb-3">{testimonials.tagline}</p>
        <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-[#1A1A1A] leading-tight">
          {testimonials.heading}
        </h2>
        <p class="mt-5 text-gray-600 text-lg leading-relaxed">
          {testimonials.subtext}
        </p>
      </div>

      <!-- Rating summary card -->
      <div class="shrink-0 bg-[#F5F5F5] border border-gray-200 rounded-2xl px-6 py-5 flex items-center gap-5">
        <div>
          <div class="font-display text-4xl font-extrabold text-[#1A1A1A] leading-none">5.0</div>
          <div class="text-[#E31E24] text-base tracking-tight mt-1">★★★★★</div>
        </div>
        <div class="text-sm text-gray-600 leading-snug">
          <div class="font-semibold text-[#1A1A1A]">Google Reviews</div>
          <div>Rated by Taree<br/>drivers and beyond</div>
        </div>
      </div>
    </div>

    <!-- Reviews grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.reviews.map((review) => (
        <div class="bg-white rounded-2xl p-7 border border-gray-200 hover:shadow-xl hover:border-[#E31E24]/30 transition-all duration-300 hover:-translate-y-1">
          <!-- Stars -->
          <div class="text-[#E31E24] text-lg mb-4 tracking-tight" aria-label={`${review.stars} out of 5 stars`}>
            {renderStars(review.stars)}
          </div>

          <!-- Quote text -->
          <blockquote class="text-gray-700 text-[15px] leading-relaxed mb-6">
            “{review.text}”
          </blockquote>

          <!-- Reviewer info -->
          <div class="flex items-center gap-3 pt-5 border-t border-gray-100">
            <div class="w-10 h-10 rounded-full bg-[#E31E24] flex items-center justify-center text-white font-bold text-sm shrink-0">
              {getInitial(review.name)}
            </div>
            <div>
              <div class="font-semibold text-[#1A1A1A] text-sm">{review.name}</div>
              <div class="text-gray-500 text-xs">{review.vehicle} · {review.location}</div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Google review link -->
    <div class="text-center mt-12">
      <a
        href={siteContent.googleMapsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-[#E31E24] font-semibold hover:underline text-sm"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
        </svg>
        See all our Google reviews ★★★★★
      </a>
    </div>

  </div>
</section>
