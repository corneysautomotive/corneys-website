---
interface Props {
  heading?: string;
  subtext?: string;
}
const {
  heading = "Ready to Book Your Service?",
  subtext = "Give us a call or send us a message. We'll get you sorted."
} = Astro.props;
---

<section
  class="py-20 lg:py-28 bg-[#E31E24] relative overflow-hidden"
  aria-label="Book a service call to action"
>
  <!-- Diagonal texture overlay -->
  <div class="absolute inset-0 opacity-[0.08]" style="background-image: repeating-linear-gradient(45deg, rgba(255,255,255,0.9) 0, rgba(255,255,255,0.9) 1px, transparent 0, transparent 50%); background-size: 10px 10px;"></div>

  <!-- Dark overlay for depth -->
  <div class="absolute inset-0 bg-gradient-to-br from-[#C01820] via-[#E31E24] to-[#FF2E35] opacity-70"></div>

  <!-- Large decorative gear hint (bottom right) -->
  <div class="absolute -right-16 -bottom-16 w-64 h-64 opacity-10 pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 200 200" fill="none">
      <circle cx="100" cy="100" r="80" stroke="white" stroke-width="8"/>
      <circle cx="100" cy="100" r="50" stroke="white" stroke-width="4"/>
      <line x1="100" y1="20" x2="100" y2="180" stroke="white" stroke-width="3"/>
      <line x1="20" y1="100" x2="180" y2="100" stroke="white" stroke-width="3"/>
      <line x1="44" y1="44" x2="156" y2="156" stroke="white" stroke-width="2"/>
      <line x1="156" y1="44" x2="44" y2="156" stroke="white" stroke-width="2"/>
    </svg>
  </div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-4 reveal">
      {heading}
    </h2>
    <p class="text-red-100 text-lg mb-10 max-w-xl mx-auto reveal">{subtext}</p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center reveal">
      <a
        href="tel:0265526131"
        class="phone-pulse inline-flex items-center justify-center gap-3 bg-white text-[#E31E24] hover:bg-gray-100 font-bold text-xl px-10 py-5 rounded-xl transition-all hover:scale-105 hover:shadow-xl min-h-[64px]"
        aria-label="Call Corney's Automotive on (02) 6552 6131"
      >
        <svg class="w-6 h-6 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
        </svg>
        (02) 6552 6131
      </a>
      <a
        href="/contact/"
        class="inline-flex items-center justify-center gap-2 border-2 border-white/60 text-white hover:bg-white/10 font-semibold text-lg px-8 py-4 rounded-xl transition-all hover:scale-105 min-h-[64px]"
      >
        Send Us a Message
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <p class="mt-8 text-red-200 text-sm reveal flex items-center justify-center gap-2">
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      16 Albert Lane, Taree NSW 2430 &nbsp;·&nbsp; Mon–Fri 8:30am–4:30pm · Sat 8:30am–11am
    </p>
  </div>
</section>
