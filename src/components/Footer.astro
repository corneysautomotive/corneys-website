---
import siteContent from '../content/site.json';

const currentYear = new Date().getFullYear();
---

<footer class="bg-[#1A1A1A] text-gray-400 pt-12 pb-6">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 pb-10 border-b border-gray-700">

      <!-- Brand -->
      <div>
        <img
          src="/logos/logo-footer-transparent.png"
          alt="Corney's Automotive Services"
          width="220"
          height="66"
          class="h-14 w-auto object-contain mb-4"
          loading="lazy"
        />
        <p class="text-sm leading-relaxed text-gray-400 mb-4">
          {siteContent.footerTagline}
        </p>
        <!-- Social links -->
        <div class="flex items-center gap-3">
          <a href={siteContent.facebook} target="_blank" rel="noopener noreferrer"
            class="w-9 h-9 rounded-full bg-[#2A2A2A] hover:bg-[#E31E24] flex items-center justify-center transition-colors"
            aria-label="Corney's Automotive on Facebook">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
          <a href={siteContent.instagram} target="_blank" rel="noopener noreferrer"
            class="w-9 h-9 rounded-full bg-[#2A2A2A] hover:bg-[#E31E24] flex items-center justify-center transition-colors"
            aria-label="Corney's Automotive on Instagram">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-[#E31E24] transition-colors">Home</a></li>
          <li><a href="/services/" class="hover:text-[#E31E24] transition-colors">Our Services</a></li>
          <li><a href="/about/" class="hover:text-[#E31E24] transition-colors">About Us</a></li>
          <li><a href="/contact/" class="hover:text-[#E31E24] transition-colors">Contact & Booking</a></li>
          <li><a href="/privacy/" class="hover:text-[#E31E24] transition-colors">Privacy Policy</a></li>
          <li><a href="/terms/" class="hover:text-[#E31E24] transition-colors">Terms & Conditions</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Contact Us</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-[#E31E24] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span>{siteContent.addressStreet}<br />{siteContent.addressCity}</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[#E31E24] shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
            <a href={`tel:${siteContent.phoneTel}`} class="hover:text-white transition-colors font-medium">
              {siteContent.phone}
            </a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-[#E31E24] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span>{siteContent.hoursWeekday}<br />{siteContent.hoursSaturday}<br />{siteContent.hoursSunday}</span>
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="pt-6 flex flex-col sm:flex-row justify-between items-center gap-2 text-xs text-gray-500">
      <p>© {currentYear} {siteContent.businessName}. All rights reserved.</p>
      <p>{siteContent.address}{siteContent.abn ? ` · ABN: ${siteContent.abn}` : ' · ABN: available on request'}</p>
    </div>

  </div>
</footer>
