---
import siteContent from '../content/site.json';

interface Props {
  currentPage?: string;
}
const { currentPage = '/' } = Astro.props;

const nav = [
  { href: '/', label: 'Home' },
  { href: '/services/', label: 'Services' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
  { href: '/quote/', label: 'Get a Quote' }
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 bg-[#1A1A1A] text-white transition-all duration-300"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center shrink-0" aria-label="Corney's Automotive Services — Home">
        <img
          src="/logos/logo-header-transparent.png"
          alt="Corney's Automotive Services"
          width="160"
          height="48"
          class="h-10 w-auto object-contain"
        />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-6 lg:gap-8" aria-label="Main navigation">
        {nav.map(({ href, label }) => (
          label === 'Get a Quote'
            ? <a href={href} class={`text-sm font-bold px-4 py-1.5 rounded-lg border-2 transition-colors ${
                currentPage === href
                  ? 'border-[#E31E24] text-[#E31E24]'
                  : 'border-[#E31E24] text-[#E31E24] hover:bg-[#E31E24] hover:text-white'
              }`}>{label}</a>
            : <a href={href} class={`text-sm font-medium transition-colors hover:text-[#E31E24] ${
                currentPage === href ? 'text-[#E31E24]' : 'text-gray-300'
              }`}>{label}</a>
        ))}
      </nav>

      <!-- Desktop CTA -->
      <div class="hidden md:flex items-center gap-3">
        <a
          href={`tel:${siteContent.phoneTel}`}
          class="text-sm font-semibold text-white hover:text-[#E31E24] transition-colors"
          aria-label={`Call us on ${siteContent.phone}`}
        >
          {siteContent.phone}
        </a>
        <a
          href="/contact/"
          class="bg-[#E31E24] hover:bg-red-700 text-white text-sm font-semibold px-4 py-2 rounded transition-colors"
        >
          Book a Service
        </a>
      </div>

      <!-- Mobile: phone + hamburger -->
      <div class="flex md:hidden items-center gap-3">
        <a
          href={`tel:${siteContent.phoneTel}`}
          class="inline-flex items-center gap-1.5 text-white bg-[#E31E24] hover:bg-red-700 font-bold text-xs px-3 py-1.5 rounded transition-colors"
          aria-label={`Call ${siteContent.phone}`}
        >
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
          Call Now
        </a>
        <button
          id="mobile-menu-btn"
          class="p-2 text-gray-300 hover:text-white"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-[#2C2C2C] border-t border-gray-700"
    role="dialog"
    aria-label="Mobile navigation"
  >
    <nav class="max-w-6xl mx-auto px-4 py-4 flex flex-col gap-1">
      {nav.map(({ href, label }) => (
        <a
          href={href}
          class={`py-3 px-2 text-base font-medium border-b border-gray-700 last:border-0 transition-colors hover:text-[#E31E24] ${
            currentPage === href ? 'text-[#E31E24]' : 'text-gray-200'
          }`}
        >
          {label}
        </a>
      ))}
      <a
        href="/contact/"
        class="mt-3 bg-[#E31E24] text-white text-center font-semibold py-3 rounded"
      >
        Book a Service
      </a>
    </nav>
  </div>
</header>

<!-- Spacer so content doesn't hide behind fixed header -->
<div class="h-16 lg:h-20"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
