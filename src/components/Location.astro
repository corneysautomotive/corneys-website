---
// Location + hours section with Google Maps embed
---

<section class="py-20 lg:py-28 bg-white" id="location" aria-label="Location and hours">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="max-w-2xl mb-14 lg:mb-16">
      <p class="text-[#E31E24] font-semibold text-xs uppercase tracking-[0.2em] mb-3">Find Us</p>
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-[#1A1A1A] leading-tight">
        Come see us in Taree.
      </h2>
      <p class="mt-5 text-gray-600 text-lg leading-relaxed">
        Drop in, give us a ring, or book online. We're right in the middle of town.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">

      <!-- Map -->
      <div class="rounded-2xl overflow-hidden shadow-lg border border-gray-200 aspect-video lg:aspect-auto lg:h-[28rem]">
        <iframe
          title="Corney's Automotive Services location map"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3367.8!2d152.4571!3d-31.9046!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s16+Albert+Lane%2C+Taree+NSW+2430!5e0!3m2!1sen!2sau!4v1234567890"
          width="100%"
          height="100%"
          style="border:0; min-height:300px;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>

      <!-- Details -->
      <div class="space-y-7">

        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-lg bg-[#E31E24]/10 flex items-center justify-center shrink-0 text-[#E31E24]">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <div>
            <p class="font-semibold text-[#1A1A1A] mb-1">Address</p>
            <p class="text-gray-600">16 Albert Lane<br />Taree NSW 2430</p>
            <a
              href="https://maps.google.com/?q=16+Albert+Lane,+Taree+NSW+2430"
              target="_blank"
              rel="noopener noreferrer"
              class="text-[#E31E24] text-sm font-medium hover:underline mt-1 inline-block"
            >
              Get directions →
            </a>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-lg bg-[#E31E24]/10 flex items-center justify-center shrink-0 text-[#E31E24]">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
          </div>
          <div>
            <p class="font-semibold text-[#1A1A1A] mb-1">Phone</p>
            <a
              href="tel:0265526131"
              class="text-gray-600 hover:text-[#E31E24] transition-colors font-medium text-lg"
            >
              (02) 6552 6131
            </a>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-lg bg-[#E31E24]/10 flex items-center justify-center shrink-0 text-[#E31E24]">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <p class="font-semibold text-[#1A1A1A] mb-2">Opening Hours</p>
            <table class="text-sm text-gray-600 w-full">
              <tbody>
                <tr>
                  <td class="py-1 pr-6 font-medium">Monday – Friday</td>
                  <td>8:30am – 4:30pm</td>
                </tr>
                <tr>
                  <td class="py-1 pr-6 text-gray-400">Saturday</td>
                  <td class="text-gray-400">8:30am – 11:00am</td>
                </tr>
                <tr>
                  <td class="py-1 pr-6 text-gray-400">Sunday</td>
                  <td class="text-gray-400">Closed</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="pt-4">
          <a
            href="/contact/"
            class="inline-flex items-center gap-2 bg-[#E31E24] hover:bg-red-700 text-white font-semibold px-6 py-3 rounded-lg transition-colors"
          >
            Book a Service
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

      </div>
    </div>
  </div>
</section>
