---
interface Props {
  title?: string;
  subtitle?: string;
  showAll?: boolean;
}
const {
  title = "What We Do",
  subtitle = "From your annual service to a full mechanical overhaul — we handle it all under one roof.",
  showAll = false
} = Astro.props;

const services = [
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>`,
    name: "Logbook Servicing",
    desc: "Keep your new car warranty intact. We follow manufacturer schedules and stamp your logbook.",
    href: "/services/#logbook"
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    name: "General Servicing & Repairs",
    desc: "Oil changes, filters, belts, hoses — regular maintenance that keeps your car running reliably.",
    href: "/services/#general"
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" stroke-width="1.5"/><circle cx="12" cy="12" r="3" stroke-width="1.5"/><path stroke-linecap="round" stroke-width="1.5" d="M12 3v3M12 18v3M3 12h3M18 12h3"/></svg>`,
    name: "Brakes",
    desc: "Pads, rotors, callipers, brake fluid — we won't let you drive away on unsafe brakes.",
    href: "/services/#brakes"
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`,
    name: "Diagnostics",
    desc: "Modern scan tools to read fault codes and pinpoint exactly what's wrong — no guesswork.",
    href: "/services/#diagnostics"
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>`,
    name: "Air Conditioning",
    desc: "Regas, repairs, and full AC service. Stay comfortable on those hot Taree summers.",
    href: "/services/#aircon"
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    name: "Batteries & Electrical",
    desc: "Battery testing, replacement, and electrical fault-finding for all vehicles.",
    href: "/services/#electrical"
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>`,
    name: "Pink Slips",
    desc: "Annual safety inspection required for NSW rego renewal. Fast, reliable, and done right.",
    href: "/services/#pinkslips",
    highlight: true
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    name: "Blue Slips (AUVIS)",
    desc: "Need to register an unregistered vehicle or bring rego in from interstate? We're an authorised AUVIS inspection station.",
    href: "/services/#blueslips",
    highlight: true
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>`,
    name: "Defect Clearances",
    desc: "Received an RMS defect notice? We repair the issue and issue the clearance certificate so you can get back on the road.",
    href: "/services/#defects",
    highlight: true,
    homeHidden: true
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>`,
    name: "Pre-Purchase Inspections",
    desc: "Buying a used car? Let us check it over before you sign anything. It could save you thousands.",
    href: "/services/#prepurchase"
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>`,
    name: "Suspension & Steering",
    desc: "Shocks, struts, ball joints, wheel alignments — if it handles your car's handling, we handle it.",
    href: "/services/#suspension"
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>`,
    name: "Cooling Systems",
    desc: "Radiator flushes, coolant leaks, thermostat replacement — keep your engine running cool.",
    href: "/services/#cooling"
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"/></svg>`,
    name: "4WD & Fleet",
    desc: "From utes and 4WDs to small business fleets — serviced and maintained to keep your work vehicles on the road.",
    href: "/services/#fleet"
  }
];

const displayServices = showAll ? services : services.filter(s => !s.homeHidden).slice(0, 8);
---

<section class="py-16 lg:py-24 bg-white" id="services-overview" aria-label="Our services">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-12 reveal">
      <p class="text-[#E31E24] font-semibold text-sm uppercase tracking-widest mb-2">Our Services</p>
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-[#1A1A1A]">{title}</h2>
      <span class="accent-line mx-auto"></span>
      <p class="mt-4 text-gray-600 text-lg max-w-2xl mx-auto">{subtitle}</p>
    </div>

    <!-- Services grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {displayServices.map((service) => (
        <a
          href={service.href}
          class={`service-card-reveal group flex gap-4 p-6 rounded-xl border transition-all duration-300 hover:shadow-xl hover:border-[#E31E24] hover:-translate-y-1 hover:shadow-[#E31E24]/5 bg-white ${
            service.highlight ? '' : 'border-gray-200'
          }`}
          style={`opacity:0; transform:translateY(24px);${service.highlight ? ' border: 2px solid #E31E24;' : ''}`}
        >
          <div class={`shrink-0 w-12 h-12 rounded-xl flex items-center justify-center text-[#E31E24] transition-all duration-300 group-hover:scale-110 ${
            service.highlight ? 'bg-[#E31E24]/10 group-hover:bg-[#E31E24]/20' : 'bg-[#F5F5F5] group-hover:bg-[#E31E24]/10'
          }`}
            set:html={service.icon}
          />
          <div class="min-w-0">
            <h3 class="font-semibold text-[#1A1A1A] text-sm mb-1.5 group-hover:text-[#E31E24] transition-colors duration-300">
              {service.name}
              {service.highlight && <span class="ml-2 text-[10px] font-bold text-[#E31E24] uppercase tracking-wide bg-[#E31E24]/10 px-1.5 py-0.5 rounded">NSW Auth.</span>}
            </h3>
            <p class="text-gray-500 text-xs leading-relaxed">{service.desc}</p>
          </div>
        </a>
      ))}
    </div>

    {!showAll && (
      <div class="text-center mt-10 reveal">
        <a
          href="/services/"
          class="inline-flex items-center gap-2 text-[#E31E24] font-semibold hover:underline"
        >
          View all 13 services
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    )}

  </div>
</section>
