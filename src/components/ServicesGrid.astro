const displayServices = showAll ? services : services.filter(s => !s.homeHidden).slice(0, 8);
---

<section class="py-20 lg:py-28 bg-white" id="services-overview" aria-label="Our services">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header — left-aligned, JAX-style -->
    <div class="max-w-2xl mb-14 lg:mb-16">
      <p class="text-[#E31E24] font-semibold text-xs uppercase tracking-[0.2em] mb-3">Our Services</p>
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-[#1A1A1A] leading-tight">{title}</h2>
      <p class="mt-5 text-gray-600 text-lg leading-relaxed">{subtitle}</p>
    </div>

    <!-- Services grid — clean white cards, premium icon set -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {displayServices.map((service) => (
        <a
          href={service.href}
          class={`service-card-reveal group relative flex flex-col p-6 rounded-2xl bg-white border border-gray-100 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-0.5 ${
            service.highlight ? 'hover:border-[#E31E24]/40' : 'hover:border-gray-200'
          }`}
        >
          {service.highlight && service.badge && (
            <span class="absolute top-5 right-5 text-[10px] font-bold text-[#E31E24] uppercase tracking-wider bg-[#E31E24]/10 px-2 py-1 rounded">{service.badge}</span>
          )}

          <div
            class="w-14 h-14 rounded-2xl bg-red-50 flex items-center justify-center text-[#E31E24] mb-4 transition-transform duration-300 group-hover:scale-105"
            set:html={service.icon}
          />

          <h3 class="text-lg font-bold text-gray-900 mb-2 leading-tight group-hover:text-[#E31E24] transition-colors duration-300">
            {service.name}
          </h3>
          <p class="text-gray-500 text-sm leading-relaxed mb-4">{service.desc}</p>

          <span class="mt-auto inline-flex items-center gap-1.5 text-[#E31E24] text-sm font-semibold group-hover:underline">
            Find out more
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      ))}
    </div>

    {!showAll && (
      <div class="mt-14 text-center">
        <a
          href="/services/"
          class="inline-flex items-center gap-2 bg-[#1A1A1A] hover:bg-black text-white font-semibold px-7 py-3.5 rounded-lg transition-all hover:scale-[1.02]"
        >
          View all services
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    )}

  </div>
</section>
