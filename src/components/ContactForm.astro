---
// Contact / booking request form — wired to Formspree (set up post-Opus before final launch)
const FORMSPREE_ENDPOINT = "https://formspree.io/f/REPLACE_WITH_ID";
---

<section class="py-16 lg:py-24 bg-[#F5F5F5]" id="contact-form" aria-label="Contact form">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-10 reveal">
      <p class="text-[#E31E24] font-semibold text-sm uppercase tracking-widest mb-2">Get in Touch</p>
      <h2 class="font-display text-3xl font-bold text-[#1A1A1A]">Send Us a Message</h2>
      <span class="accent-line mx-auto"></span>
      <p class="mt-4 text-gray-600">
        Fill out the form below and we'll get back to you as soon as possible.
        <br class="hidden sm:block" />
        Rather call? <a href="tel:0265526131" class="text-[#E31E24] font-medium hover:underline">(02) 6552 6131</a>
      </p>
    </div>

    <form
      id="contact-form-el"
      action={FORMSPREE_ENDPOINT}
      method="POST"
      class="reveal bg-white rounded-2xl shadow-sm border border-gray-200 p-6 sm:p-8 space-y-5"
      novalidate
    >
      <!-- Name -->
      <div>
        <label for="name" class="block text-sm font-semibold text-[#1A1A1A] mb-1.5">
          Your Name <span class="text-[#E31E24]">*</span>
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          autocomplete="name"
          placeholder="Jarrad Smith"
          class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#E31E24] focus:border-transparent transition"
        />
      </div>

      <!-- Phone -->
      <div>
        <label for="phone" class="block text-sm font-semibold text-[#1A1A1A] mb-1.5">
          Phone Number <span class="text-[#E31E24]">*</span>
        </label>
        <input
          type="tel"
          id="phone"
          name="phone"
          required
          autocomplete="tel"
          placeholder="0400 000 000"
          class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#E31E24] focus:border-transparent transition"
        />
      </div>

      <!-- Email -->
      <div>
        <label for="email" class="block text-sm font-semibold text-[#1A1A1A] mb-1.5">
          Email Address
        </label>
        <input
          type="email"
          id="email"
          name="email"
          autocomplete="email"
          placeholder="you@email.com"
          class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#E31E24] focus:border-transparent transition"
        />
      </div>

      <!-- Vehicle -->
      <div>
        <label for="vehicle" class="block text-sm font-semibold text-[#1A1A1A] mb-1.5">
          Vehicle (make, model, year)
        </label>
        <input
          type="text"
          id="vehicle"
          name="vehicle"
          placeholder="e.g. 2018 Toyota Camry"
          class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#E31E24] focus:border-transparent transition"
        />
      </div>

      <!-- Service needed -->
      <div>
        <label for="service" class="block text-sm font-semibold text-[#1A1A1A] mb-1.5">
          Service Required
        </label>
        <select
          id="service"
          name="service"
          class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#E31E24] focus:border-transparent transition bg-white"
        >
          <option value="">Select a service...</option>
          <option>Logbook Servicing</option>
          <option>General Servicing & Repairs</option>
          <option>Brakes</option>
          <option>Suspension & Steering</option>
          <option>Air Conditioning</option>
          <option>Batteries & Electrical</option>
          <option>Cooling Systems</option>
          <option>Diagnostics</option>
          <option>Pink Slip (Roadworthy)</option>
          <option>Blue Slip (AUVIS Inspection)</option>
          <option>Defect Clearance</option>
          <option>Pre-Purchase Inspection</option>
          <option>4WD / Fleet</option>
          <option>Other / Not Sure</option>
        </select>
      </div>

      <!-- Message -->
      <div>
        <label for="message" class="block text-sm font-semibold text-[#1A1A1A] mb-1.5">
          Tell Us More
        </label>
        <textarea
          id="message"
          name="message"
          rows="4"
          placeholder="Describe the issue or what you'd like booked in..."
          class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#E31E24] focus:border-transparent transition resize-y"
        ></textarea>
      </div>

      <!-- Consent -->
      <div class="flex items-start gap-3">
        <input
          type="checkbox"
          id="consent"
          name="consent"
          required
          class="mt-1 h-4 w-4 rounded border-gray-300 text-[#E31E24] focus:ring-[#E31E24] shrink-0"
        />
        <label for="consent" class="text-xs text-gray-500 leading-relaxed">
          By submitting this form I agree to Corney's Automotive Services'
          <a href="/privacy/" class="text-[#E31E24] hover:underline" target="_blank">Privacy Policy</a>
          and
          <a href="/terms/" class="text-[#E31E24] hover:underline" target="_blank">Terms & Conditions</a>.
        </label>
      </div>

      <!-- Submit -->
      <button
        type="submit"
        class="w-full bg-[#E31E24] hover:bg-red-700 text-white font-bold py-4 rounded-lg transition-colors text-base"
      >
        Send Message
      </button>

      <p class="text-center text-xs text-gray-400">
        We'll reply within one business day. For urgent matters please call us directly.
      </p>
    </form>

    <!-- Success / error state (JS-driven) -->
    <div id="form-success" class="hidden mt-6 p-5 bg-green-50 border border-green-200 rounded-xl text-center">
      <p class="text-green-800 font-semibold text-base">Message sent! ✅</p>
      <p class="text-green-700 text-sm mt-1">We'll be in touch soon. If it's urgent, call us on <a href="tel:0265526131" class="font-bold">(02) 6552 6131</a>.</p>
    </div>
    <div id="form-error" class="hidden mt-6 p-5 bg-red-50 border border-red-200 rounded-xl text-center">
      <p class="text-red-800 font-semibold text-base">Something went wrong.</p>
      <p class="text-red-700 text-sm mt-1">Please try again or call us on <a href="tel:0265526131" class="font-bold">(02) 6552 6131</a>.</p>
    </div>

  </div>
</section>

<script>
  const form = document.getElementById('contact-form-el') as HTMLFormElement | null;
  const success = document.getElementById('form-success');
  const error = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' }
      });
      if (res.ok) {
        form.classList.add('hidden');
        success?.classList.remove('hidden');
      } else {
        error?.classList.remove('hidden');
      }
    } catch {
      error?.classList.remove('hidden');
    }
  });
</script>
