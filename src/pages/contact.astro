---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import BookingForm from '../components/BookingForm.astro';
import Location from '../components/Location.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import MobileCTABar from '../components/MobileCTABar.astro';
import contactContent from '../content/contact.json';

const { hero, howItWorks } = contactContent;
---

<Layout
  title="Contact & Booking — Corney's Automotive Services Taree"
  description="Contact Corney's Automotive Services in Taree NSW. Call (02) 6552 6131, book online, or visit us at 16 Albert Lane Taree. Mon–Fri 8:30am–4:30pm, Sat 8:30am–11am."
  canonical="/contact/"
>
  <Header currentPage="/contact/" />
  <main>

    <!-- Hero -->
    <section class="bg-[#1A1A1A] py-14 relative overflow-hidden" aria-label="Contact page header">
      <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-[#E31E24]"></div>
      <div class="max-w-4xl mx-auto px-6 sm:px-8 text-center">
        <p class="text-[#E31E24] font-semibold text-sm uppercase tracking-widest mb-3">Get in Touch</p>
        <h1 class="font-display text-4xl sm:text-5xl font-extrabold text-white mb-4">Contact & Booking</h1>
        <p class="text-gray-400 text-lg max-w-xl mx-auto">
          Give us a call, send us a message, or just come in. We're easy to deal with.
        </p>

        <!-- Quick contact -->
        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="tel:0265526131"
            class="phone-pulse inline-flex items-center justify-center gap-2 bg-[#E31E24] hover:bg-red-700 text-white font-bold text-xl px-8 py-4 rounded-xl transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
            </svg>
            (02) 6552 6131
          </a>
        </div>
        <p class="mt-3 text-gray-500 text-sm">Mon–Fri 8:30am – 4:30pm &nbsp;·&nbsp; Sat 8:30am – 11:00am</p>
      </div>
    </section>

    <!-- How to book explainer -->
    <section class="py-12 bg-[#F5F5F5]" aria-label="How to book">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-8 reveal">
          <h2 class="font-display text-2xl font-bold text-[#1A1A1A]">How It Works</h2>
          <span class="accent-line mx-auto"></span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          {howItWorks.steps.map((step) => (
            <div class="reveal text-center">
              <div class="w-12 h-12 rounded-full bg-[#E31E24] text-white text-xl font-bold flex items-center justify-center mx-auto mb-3">{step.number}</div>
              <h3 class="font-semibold text-[#1A1A1A] mb-1">{step.title}</h3>
              <p class="text-gray-500 text-sm">{step.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <BookingForm />
    <Location />

  </main>
  <Footer />
  <WhatsAppButton />
  <MobileCTABar />
</Layout>
