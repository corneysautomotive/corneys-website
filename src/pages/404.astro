---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Page Not Found — Corney's Automotive Services"
  description="Page not found. Return to Corney's Automotive Services homepage."
>
  <Header />
  <main>
    <section class="min-h-[60vh] flex items-center justify-center py-20 bg-white">
      <div class="text-center px-4">
        <p class="text-[#E31E24] text-7xl font-extrabold font-display mb-4">404</p>
        <h1 class="font-display text-2xl font-bold text-[#1A1A1A] mb-3">Page Not Found</h1>
        <p class="text-gray-500 mb-8">That page doesn't exist. Try one of these instead:</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/" class="bg-[#E31E24] text-white font-semibold px-6 py-3 rounded-lg hover:bg-red-700 transition-colors">Go Home</a>
          <a href="/services/" class="border border-gray-300 text-gray-700 font-semibold px-6 py-3 rounded-lg hover:border-[#E31E24] hover:text-[#E31E24] transition-colors">Our Services</a>
          <a href="/contact/" class="border border-gray-300 text-gray-700 font-semibold px-6 py-3 rounded-lg hover:border-[#E31E24] hover:text-[#E31E24] transition-colors">Contact Us</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
