---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import StatsBar from '../components/StatsBar.astro';
import AirconCallout from '../components/AirconCallout.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import HowItWorks from '../components/HowItWorks.astro';
import WhyUs from '../components/WhyUs.astro';
import Testimonials from '../components/Testimonials.astro';
import BookingCTA from '../components/BookingCTA.astro';
import Location from '../components/Location.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import MobileCTABar from '../components/MobileCTABar.astro';
---

<Layout
  title="Corney's Automotive Services — ARCtick Licensed Mechanic in Taree NSW"
  description="Taree's ARCtick-licensed workshop. Fixed-price AC regas $189, blue slips, pink slips, defect clearances, logbook servicing. 20 years local. Call (02) 6552 6131."
  canonical="/"
>
  <Header currentPage="/" />
  <main>
    <!-- 1. Hero -->
    <Hero />

    <!-- 2. Stats bar (credibility) -->
    <StatsBar />

    <!-- 3. ARCtick / AC callout — the single biggest competitive edge -->
    <AirconCallout />

    <!-- 4. Services grid -->
    <ServicesGrid
      title="Everything Your Car Needs, Under One Roof"
      subtitle="Logbook servicing, brakes, AC, pink slips, blue slips, defect clearances — all handled in-house in Taree."
    />

    <!-- 5. Why Us -->
    <WhyUs />

    <!-- 6. Testimonials -->
    <Testimonials />

    <!-- 7. How It Works + CTA -->
    <HowItWorks />
    <BookingCTA
      heading="Book in. Drop it off. Drive away fixed."
      subtext="Same-week bookings in most cases. Honest quote before any work starts. Your car handled properly."
    />

    <!-- 8. Location -->
    <Location />
  </main>
  <Footer />
  <WhatsAppButton />
  <MobileCTABar />
</Layout>
