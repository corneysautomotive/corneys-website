---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const {
  title,
  description = "Corney's Automotive Services — trusted mechanic in Taree NSW. Logbook servicing, brakes, air conditioning, blue slips, pink slips, defect clearances and more. Call (02) 6552 6131.",
  canonical
} = Astro.props;

const siteUrl = 'https://corneysautomotive.com.au';
const canonicalUrl = canonical ? `${siteUrl}${canonical}` : siteUrl + Astro.url.pathname;
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_AU" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Sora:wght@600;700;800&display=swap" rel="stylesheet" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- LocalBusiness Schema -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "AutoRepair",
        "name": "Corney's Automotive Services",
        "image": "https://corneysautomotive.com.au/logos/Corneys%20Automotive%20Services%20Colour%20on%20White.jpg",
        "url": "https://corneysautomotive.com.au",
        "telephone": "+61265526131",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "16 Albert Lane",
          "addressLocality": "Taree",
          "addressRegion": "NSW",
          "postalCode": "2430",
          "addressCountry": "AU"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": -31.9046,
          "longitude": 152.4571
        },
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
            "opens": "08:30",
            "closes": "16:30"
          },
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Saturday"],
            "opens": "08:30",
            "closes": "11:00"
          }
        ],
        "priceRange": "$$",
        "servesCuisine": null,
        "areaServed": {
          "@type": "City",
          "name": "Taree"
        },
        "sameAs": []
      }
    </script>

    <title>{title}</title>
    <!-- Safety: ensure body is always visible even if JS fails -->
    <style>body { opacity: 1 !important; }</style>
  </head>
  <body>
    <slot />

    <!-- GSAP -->
    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      // Page entrance — subtle fade in
      gsap.from('body', { opacity: 0, duration: 0.3, ease: 'power2.out' });

      // Scroll reveals
      gsap.utils.toArray<HTMLElement>('.reveal').forEach((el) => {
        gsap.to(el, {
          opacity: 1,
          y: 0,
          duration: 0.7,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 88%',
            once: true
          }
        });
      });

      // Staggered service cards
      gsap.utils.toArray<HTMLElement>('.service-card-reveal').forEach((el, i) => {
        gsap.to(el, {
          opacity: 1,
          y: 0,
          duration: 0.35,
          ease: 'power2.out',
          delay: i * 0.03,
          scrollTrigger: {
            trigger: el,
            start: 'top 95%',
            once: true
          }
        });
      });

      // Sticky header
      const header = document.getElementById('site-header');
      if (header) {
        ScrollTrigger.create({
          start: 100,
          onEnter: () => header.classList.add('shadow-lg', 'bg-opacity-95'),
          onLeaveBack: () => header.classList.remove('shadow-lg', 'bg-opacity-95')
        });
      }
    </script>
  </body>
</html>
